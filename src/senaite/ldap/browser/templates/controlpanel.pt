<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      xmlns:i18n="http://xml.zope.org/namespaces/i18n"
      lang="en"
      metal:use-macro="context/prefs_main_template/macros/master"
      i18n:domain="senaite.ldap">
<body>

<metal:main metal:fill-slot="prefs_configlet_main"
            tal:define="portal_url context/@@plone_portal_state/portal_url;
                        server view/server_data;
                        cache view/cache_data;
                        users view/users_data;
                        groups view/groups_data;
                        scope_choices view/scope_choices;
                        expires_units view/expires_unit_choices;">

  <style>
    /* Override prefs container width — defaults are too narrow for DNs and URIs. */
    .senaite-ldap-form .form-control,
    .senaite-ldap-form .form-control-lg {
      width: 100%;
      max-width: 100%;
    }
    .senaite-ldap-form .form-control.text-monospace {
      font-size: 0.95rem;
    }
    .senaite-ldap-form textarea.form-control {
      font-size: 0.9rem;
    }
    .senaite-ldap-form .nav-tabs .nav-link {
      padding: 0.6rem 1.2rem;
      font-weight: 500;
    }
    .senaite-ldap-form .tab-pane > .field-row {
      max-width: 900px;
    }
    .senaite-ldap-form .section-heading {
      font-size: 0.9rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: #6c757d;
      margin: 1.5rem 0 0.75rem 0;
    }
    .senaite-ldap-form .helptext {
      font-size: 0.85rem;
    }
    /* LDAP search */
    .senaite-ldap-form .result-row { cursor: pointer; }
    .senaite-ldap-form .result-row.is-open { background: #eef4ff; }
    .senaite-ldap-form .attrs-cell { padding-left: 2rem; }
    .senaite-ldap-form .attrs-table {
      font-size: 0.9rem;
      border-spacing: 0;
      border-collapse: collapse;
    }
    .senaite-ldap-form .attrs-table th {
      text-align: right;
      vertical-align: top;
      padding: 0.15rem 0.6rem 0.15rem 0;
      color: #6c757d;
      font-weight: 600;
      white-space: nowrap;
    }
    .senaite-ldap-form .attrs-table td {
      vertical-align: top;
      padding: 0.15rem 0;
      font-family: var(--bs-font-monospace, monospace);
      word-break: break-all;
    }
    .senaite-ldap-form .attrs-table tr + tr th,
    .senaite-ldap-form .attrs-table tr + tr td {
      border-top: 1px solid #e9ecef;
    }
  </style>

  <a id="setup-link" class="link-parent"
     tal:attributes="href string:$portal_url/@@overview-controlpanel"
     i18n:translate="">Site Setup</a>

  <h1 i18n:translate="">LDAP / Active Directory</h1>

  <div metal:use-macro="context/global_statusmessage/macros/portal_message">
    Portal status message
  </div>

  <div class="senaite-ldap-form">

  <!-- Compact status header -->
  <div class="card bg-light mb-3"
       tal:define="connected python:bool(server['uri'])">
    <div class="card-body py-2 d-flex align-items-center">
      <div class="flex-grow-1 mr-3">
        <small class="text-muted text-uppercase"
               i18n:translate="">Target</small>
        <div tal:condition="connected"
             tal:content="server/uri"
             class="font-weight-bold text-monospace">
          ldaps://example.com:636
        </div>
        <div tal:condition="not:connected"
             class="text-muted font-italic"
             i18n:translate="">No connection URI configured</div>
        <small class="text-muted">
          <tal:b tal:condition="server/anonymous"
                 i18n:translate="">Anonymous bind</tal:b>
          <tal:b tal:condition="not:server/anonymous">
            <span i18n:translate="">Bind DN:</span>
            <code class="text-dark"
                  tal:content="server/user">cn=manager,dc=…</code>
          </tal:b>
        </small>
      </div>
      <form method="post" class="mb-0"
            tal:attributes="action string:${context/absolute_url}/@@senaite_ldapcontrolpanel">
        <button type="submit" name="form.action" value="test"
                class="btn btn-sm btn-outline-secondary"
                tal:attributes="disabled python:not connected and 'disabled' or None"
                i18n:translate="">Test connection</button>
      </form>
    </div>
  </div>

  <form method="post" id="ldap-settings-form"
        tal:attributes="action string:${context/absolute_url}/@@senaite_ldapcontrolpanel">

    <ul class="nav nav-tabs" role="tablist">
      <li class="nav-item">
        <a class="nav-link active" data-toggle="tab" href="#tab-server" role="tab"
           i18n:translate="">Server</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" data-toggle="tab" href="#tab-users" role="tab"
           i18n:translate="">Users</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" data-toggle="tab" href="#tab-groups" role="tab"
           i18n:translate="">Groups</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" data-toggle="tab" href="#tab-cache" role="tab"
           i18n:translate="">Cache</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" data-toggle="tab" href="#tab-search" role="tab"
           i18n:translate="">Search</a>
      </li>
    </ul>

    <div class="tab-content border border-top-0 p-4 mb-3 bg-white">

      <!-- ============== Server ============== -->
      <div class="tab-pane fade show active" id="tab-server" role="tabpanel">
        <div class="field-row">

          <div class="form-group">
            <label for="f-server-uri" i18n:translate="">Connection URI</label>
            <input id="f-server-uri" type="text"
                   class="form-control form-control-lg text-monospace"
                   name="server.uri"
                   placeholder="ldaps://ad.example.com:636"
                   tal:attributes="value server/uri" />
            <small class="form-text text-muted helptext"
                   i18n:translate="">
              Use <code>ldaps://</code> for TLS,
              <code>ldap://</code> for plain.
            </small>
          </div>

          <div class="form-group">
            <label for="f-server-user" i18n:translate="">Manager DN</label>
            <input id="f-server-user" type="text"
                   class="form-control form-control-lg text-monospace"
                   name="server.user"
                   placeholder="cn=manager,dc=example,dc=com"
                   tal:attributes="value server/user" />
          </div>

          <div class="form-group">
            <label for="f-server-password" i18n:translate="">Manager password</label>
            <input id="f-server-password" type="password"
                   class="form-control"
                   name="server.password"
                   placeholder="(unchanged)" autocomplete="new-password" />
            <small class="form-text text-muted helptext"
                   i18n:translate="">
              Leave blank to keep the currently stored password.
            </small>
          </div>

          <div class="form-group">
            <label for="f-server-cacert"
                   i18n:translate="">TLS CA certificate file</label>
            <input id="f-server-cacert" type="text"
                   class="form-control text-monospace"
                   name="server.tls_cacertfile"
                   placeholder="/etc/ssl/certs/example-ca.pem"
                   tal:attributes="value server/tls_cacertfile" />
            <small class="form-text text-muted helptext"
                   i18n:translate="">
              Absolute path to a CA bundle that should validate the
              server certificate. Leave empty to use the system trust
              store.
            </small>
          </div>

          <div class="form-group">
            <div class="custom-control custom-checkbox">
              <input type="checkbox" class="custom-control-input"
                     id="f-server-anonymous" name="server.anonymous" value="1"
                     tal:attributes="checked python:server['anonymous'] and 'checked' or None" />
              <label class="custom-control-label" for="f-server-anonymous"
                     i18n:translate="">Anonymous bind</label>
            </div>
            <small class="form-text text-muted helptext"
                   i18n:translate="">
              When enabled, Manager DN and password are ignored.
            </small>
          </div>

          <div class="form-group">
            <div class="custom-control custom-checkbox">
              <input type="checkbox" class="custom-control-input"
                     id="f-server-ignore-cert" name="server.ignore_cert" value="1"
                     tal:attributes="checked python:server['ignore_cert'] and 'checked' or None" />
              <label class="custom-control-label" for="f-server-ignore-cert"
                     i18n:translate="">Ignore TLS / SSL certificate errors</label>
            </div>
            <small class="form-text text-muted helptext"
                   i18n:translate="">
              Linux only. macOS dev: set
              <code>LDAPTLS_REQCERT=never</code> in the instance
              environment instead.
            </small>
          </div>

          <h6 class="section-heading"
              i18n:translate="">Timeouts &amp; paging</h6>

          <div class="form-row">
            <div class="form-group col-md-4">
              <label for="f-server-conn-timeout"
                     i18n:translate="">Connection (s)</label>
              <input id="f-server-conn-timeout" type="number" min="0"
                     class="form-control"
                     name="server.conn_timeout"
                     tal:attributes="value server/conn_timeout" />
            </div>
            <div class="form-group col-md-4">
              <label for="f-server-op-timeout"
                     i18n:translate="">Operation (s)</label>
              <input id="f-server-op-timeout" type="number" min="0"
                     class="form-control"
                     name="server.op_timeout"
                     tal:attributes="value server/op_timeout" />
            </div>
            <div class="form-group col-md-4">
              <label for="f-server-page-size"
                     i18n:translate="">Page size</label>
              <input id="f-server-page-size" type="number" min="1"
                     class="form-control"
                     name="server.page_size"
                     tal:attributes="value server/page_size" />
            </div>
          </div>
          <small class="form-text text-muted helptext"
                 i18n:translate="">
            Set page size to 1 if the server does not support paged
            results.
          </small>

        </div>
      </div>

      <!-- ============== Users ============== -->
      <div class="tab-pane fade" id="tab-users" role="tabpanel">
        <div class="field-row">

          <div class="form-group">
            <label for="f-users-basedn" i18n:translate="">Base DN</label>
            <input id="f-users-basedn" type="text"
                   class="form-control form-control-lg text-monospace"
                   name="users.baseDN"
                   placeholder="ou=people,dc=example,dc=com"
                   tal:attributes="value users/baseDN" />
          </div>

          <div class="form-group">
            <label for="f-users-query" i18n:translate="">Query filter</label>
            <input id="f-users-query" type="text"
                   class="form-control text-monospace"
                   name="users.queryFilter"
                   placeholder="(objectClass=inetOrgPerson)"
                   tal:attributes="value users/queryFilter" />
          </div>

          <div class="form-row">
            <div class="form-group col-md-4">
              <label for="f-users-scope"
                     i18n:translate="">Search scope</label>
              <select id="f-users-scope" class="form-control"
                      name="users.scope">
                <option tal:repeat="choice scope_choices"
                        tal:attributes="value python:choice[0];
                                        selected python:choice[0] == users['scope'] and 'selected' or None"
                        tal:content="python:choice[1]">SUBTREE</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label for="f-users-oc-picker"
                   i18n:translate="">Object classes</label>
            <div class="picker-and-textarea">
              <select id="f-users-oc-picker"
                      class="form-control picker"
                      multiple="multiple"
                      data-which="users"
                      data-target="f-users-oc"
                      size="6"></select>
              <div class="d-flex align-items-center mt-1">
                <button type="button"
                        class="btn btn-sm btn-outline-secondary mr-2"
                        data-action="discover-oc"
                        data-which="users"
                        data-picker="f-users-oc-picker"
                        i18n:translate="">Refresh from server</button>
                <small class="text-muted helptext"
                       data-status="f-users-oc-status"></small>
              </div>
              <textarea id="f-users-oc"
                        class="form-control text-monospace mt-2 d-none"
                        rows="3"
                        name="users.objectClasses"
                        tal:content="users/objectClasses">inetOrgPerson</textarea>
              <small class="form-text text-muted helptext mt-1"
                     i18n:translate="">
                Pick from the list, or click <em i18n:name="link">edit raw</em>
                to hand-edit (one class per line).
                <a href="#" class="reveal-textarea"
                   data-target="f-users-oc"
                   i18n:translate="">edit raw</a>
              </small>
            </div>
          </div>

          <div class="form-group">
            <label i18n:translate="">Effective user filter (preview)</label>
            <code class="d-block p-2 bg-light border rounded text-monospace"
                  data-filter-preview="users">
              (&amp;(objectClass=…))
            </code>
            <small class="form-text text-muted helptext"
                   i18n:translate="">
              Computed from the object classes and query filter
              above. Updates as you change them.
            </small>
          </div>

          <h6 class="section-heading"
              i18n:translate="">Group membership</h6>

          <div class="form-group">
            <div class="custom-control custom-checkbox">
              <input type="checkbox" class="custom-control-input"
                     id="f-users-memberof" name="users.memberOfSupport" value="1"
                     tal:attributes="checked python:users['memberOfSupport'] and 'checked' or None" />
              <label class="custom-control-label" for="f-users-memberof"
                     i18n:translate="">memberOf attribute supported</label>
            </div>
          </div>

          <div class="form-group">
            <div class="custom-control custom-checkbox">
              <input type="checkbox" class="custom-control-input"
                     id="f-users-recursive" name="users.recursiveGroups" value="1"
                     tal:attributes="checked python:users['recursiveGroups'] and 'checked' or None" />
              <label class="custom-control-label" for="f-users-recursive"
                     i18n:translate="">Recursive / nested groups</label>
            </div>
            <small class="form-text text-muted helptext"
                   i18n:translate="">
              Uses <code>LDAP_MATCHING_RULE_IN_CHAIN</code>. AD only.
            </small>
          </div>

          <div class="form-group">
            <label for="f-users-extgroups"
                   i18n:translate="">memberOf external group DNs</label>
            <textarea id="f-users-extgroups"
                      class="form-control text-monospace" rows="3"
                      name="users.memberOfExternalGroupDNs"
                      tal:content="users/memberOfExternalGroupDNs"></textarea>
            <small class="form-text text-muted helptext"
                   i18n:translate="">
              Group DNs outside the configured groups base DN are
              ignored except for those listed here. One per line.
            </small>
          </div>

          <h6 class="section-heading"
              i18n:translate="">Account expiration</h6>

          <div class="form-group">
            <div class="custom-control custom-checkbox">
              <input type="checkbox" class="custom-control-input"
                     id="f-users-expire" name="users.account_expiration" value="1"
                     tal:attributes="checked python:users['account_expiration'] and 'checked' or None" />
              <label class="custom-control-label" for="f-users-expire"
                     i18n:translate="">User accounts can expire</label>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group col-md-7">
              <label for="f-users-expires-attr"
                     i18n:translate="">Expires attribute</label>
              <input id="f-users-expires-attr" type="text"
                     class="form-control text-monospace"
                     name="users.expiresAttr"
                     tal:attributes="value users/expiresAttr" />
            </div>
            <div class="form-group col-md-5">
              <label for="f-users-expires-unit"
                     i18n:translate="">Unit</label>
              <select id="f-users-expires-unit" class="form-control"
                      name="users.expiresUnit">
                <option tal:repeat="choice expires_units"
                        tal:attributes="value python:choice[0];
                                        selected python:choice[0] == users['expiresUnit'] and 'selected' or None"
                        tal:content="python:choice[1]">Days since epoch</option>
              </select>
            </div>
          </div>

          <h6 class="section-heading"
              i18n:translate="">Attribute map</h6>

          <div class="form-group">
            <textarea class="form-control text-monospace" rows="8"
                      name="users.attrmap"
                      tal:content="users/attrmap">id=uid
login=uid
rdn=uid
email=mail
fullname=cn</textarea>
            <small class="form-text text-muted helptext"
                   i18n:translate="">
              One <code>key=value</code> mapping per line. Reserved
              keys: <code>id</code>, <code>login</code>,
              <code>rdn</code> (plus <code>groups</code> when memberOf
              is enabled). Property-sheet mappings live in the same
              list.
            </small>
          </div>

        </div>
      </div>

      <!-- ============== Groups ============== -->
      <div class="tab-pane fade" id="tab-groups" role="tabpanel">
        <div class="field-row">

          <div class="form-group">
            <label for="f-groups-basedn" i18n:translate="">Base DN</label>
            <input id="f-groups-basedn" type="text"
                   class="form-control form-control-lg text-monospace"
                   name="groups.baseDN"
                   placeholder="ou=groups,dc=example,dc=com"
                   tal:attributes="value groups/baseDN" />
          </div>

          <div class="form-group">
            <label for="f-groups-query" i18n:translate="">Query filter</label>
            <input id="f-groups-query" type="text"
                   class="form-control text-monospace"
                   name="groups.queryFilter"
                   placeholder="(objectClass=groupOfNames)"
                   tal:attributes="value groups/queryFilter" />
          </div>

          <div class="form-row">
            <div class="form-group col-md-4">
              <label for="f-groups-scope"
                     i18n:translate="">Search scope</label>
              <select id="f-groups-scope" class="form-control"
                      name="groups.scope">
                <option tal:repeat="choice scope_choices"
                        tal:attributes="value python:choice[0];
                                        selected python:choice[0] == groups['scope'] and 'selected' or None"
                        tal:content="python:choice[1]">SUBTREE</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label for="f-groups-oc-picker"
                   i18n:translate="">Object classes</label>
            <div class="picker-and-textarea">
              <select id="f-groups-oc-picker"
                      class="form-control picker"
                      multiple="multiple"
                      data-which="groups"
                      data-target="f-groups-oc"
                      size="6"></select>
              <div class="d-flex align-items-center mt-1">
                <button type="button"
                        class="btn btn-sm btn-outline-secondary mr-2"
                        data-action="discover-oc"
                        data-which="groups"
                        data-picker="f-groups-oc-picker"
                        i18n:translate="">Refresh from server</button>
                <small class="text-muted helptext"
                       data-status="f-groups-oc-status"></small>
              </div>
              <textarea id="f-groups-oc"
                        class="form-control text-monospace mt-2 d-none"
                        rows="3"
                        name="groups.objectClasses"
                        tal:content="groups/objectClasses">groupOfNames</textarea>
              <small class="form-text text-muted helptext mt-1"
                     i18n:translate="">
                Pick from the list (one of <code>groupOfNames</code>,
                <code>groupOfUniqueNames</code>, <code>posixGroup</code>,
                <code>group</code> is required), or
                <a href="#" class="reveal-textarea"
                   data-target="f-groups-oc"
                   i18n:translate="">edit raw</a>.
              </small>
            </div>
          </div>

          <div class="form-group">
            <label i18n:translate="">Effective groups filter (preview)</label>
            <code class="d-block p-2 bg-light border rounded text-monospace"
                  data-filter-preview="groups">
              (&amp;(objectClass=…))
            </code>
            <small class="form-text text-muted helptext"
                   i18n:translate="">
              Computed from the object classes and query filter
              above.
            </small>
          </div>

          <div class="form-group">
            <div class="custom-control custom-checkbox">
              <input type="checkbox" class="custom-control-input"
                     id="f-groups-memberof" name="groups.memberOfSupport" value="1"
                     tal:attributes="checked python:groups['memberOfSupport'] and 'checked' or None" />
              <label class="custom-control-label" for="f-groups-memberof"
                     i18n:translate="">memberOf attribute supported</label>
            </div>
          </div>

          <h6 class="section-heading"
              i18n:translate="">Attribute map</h6>

          <div class="form-group">
            <textarea class="form-control text-monospace" rows="6"
                      name="groups.attrmap"
                      tal:content="groups/attrmap"></textarea>
            <small class="form-text text-muted helptext"
                   i18n:translate="">
              One <code>key=value</code> mapping per line. Reserved
              keys: <code>id</code>, <code>rdn</code>.
            </small>
          </div>

        </div>
      </div>

      <!-- ============== Cache ============== -->
      <div class="tab-pane fade" id="tab-cache" role="tabpanel">
        <div class="field-row">

          <div class="form-group">
            <div class="custom-control custom-checkbox">
              <input type="checkbox" class="custom-control-input"
                     id="f-cache-on" name="cache.cache" value="1"
                     tal:attributes="checked python:cache['cache'] and 'checked' or None" />
              <label class="custom-control-label" for="f-cache-on"
                     i18n:translate="">Cache LDAP queries</label>
            </div>
          </div>

          <div class="form-group">
            <label for="f-cache-memcached"
                   i18n:translate="">Memcached server</label>
            <input id="f-cache-memcached" type="text"
                   class="form-control text-monospace"
                   name="cache.memcached"
                   placeholder="127.0.0.1:11211"
                   tal:attributes="value cache/memcached" />
            <small class="form-text text-muted helptext"
                   i18n:translate="">
              Global across all LDAP plugins. Leave empty to use the
              local in-memory cache.
            </small>
          </div>

          <div class="form-row">
            <div class="form-group col-md-4">
              <label for="f-cache-timeout"
                     i18n:translate="">Cache timeout (s)</label>
              <input id="f-cache-timeout" type="number" min="0"
                     class="form-control"
                     name="cache.timeout"
                     tal:attributes="value cache/timeout" />
            </div>
          </div>

        </div>
      </div>

      <!-- ============== Search ============== -->
      <div class="tab-pane fade" id="tab-search" role="tabpanel">
        <div class="field-row">

          <p class="text-muted"
             i18n:translate="">
            Run RFC&nbsp;4515 search filters against the configured
            LDAP directory. Click a result row to expand its full
            attribute set. Results are capped at 200 entries — narrow
            your filter if you hit the limit.
          </p>

          <div class="form-row">
            <div class="form-group col-md-3">
              <label for="ls-base"
                     i18n:translate="">Search base</label>
              <select id="ls-base" class="form-control"
                      onchange="ldapSearch.onBaseChange();">
                <option value="users"
                        i18n:translate="">Users</option>
                <option value="groups"
                        i18n:translate="">Groups</option>
                <option value="custom"
                        i18n:translate="">Custom base DN</option>
              </select>
            </div>
            <div class="form-group col-md-9">
              <label for="ls-base-dn"
                     i18n:translate="">Base DN</label>
              <input type="text" id="ls-base-dn"
                     class="form-control text-monospace"
                     disabled="disabled"
                     tal:attributes="value users/baseDN"
                     placeholder="ou=people,dc=example,dc=com" />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group col-md-9">
              <label for="ls-filter"
                     i18n:translate="">Filter</label>
              <input type="text" id="ls-filter"
                     class="form-control text-monospace"
                     value="(objectClass=*)"
                     placeholder="(uid=*)" />
            </div>
            <div class="form-group col-md-3">
              <label for="ls-scope"
                     i18n:translate="">Scope</label>
              <select id="ls-scope" class="form-control">
                <option value="sub" selected="selected">SUBTREE</option>
                <option value="one">ONELEVEL</option>
                <option value="base">BASE</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <button type="button" class="btn btn-primary"
                    onclick="ldapSearch.run();"
                    i18n:translate="">Search</button>
          </div>

          <div id="ls-status" class="mb-3"></div>

          <table id="ls-results" class="table table-sm d-none">
            <thead class="thead-light">
              <tr>
                <th class="text-monospace"
                    i18n:translate="">DN</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>

          <!-- Bridge from TAL into JS: emit configured base DNs as
               a data-* element so the script below doesn't need any
               TAL substitution inline. -->
          <span id="ls-bridge" class="d-none"
                tal:attributes="data-users-base users/baseDN;
                                data-groups-base groups/baseDN;
                                data-self-url string:${context/absolute_url}/@@senaite_ldapcontrolpanel"></span>

        </div>
      </div>

    </div>

    <div class="bg-light border-top p-3 d-flex align-items-center"
         style="position: sticky; bottom: 0; z-index: 10;">
      <button type="submit" name="form.action" value="save"
              class="btn btn-primary"
              i18n:translate="">Save changes</button>
      <span class="ml-auto text-muted small"
            i18n:translate="">
        Settings are stored on the
        <code i18n:name="plugin">pasldap</code> PAS plugin.
      </span>
    </div>

  </form>

  <!-- ====== Discovery + filter-preview ======
       Auto-populate the object-class pickers from the directory and
       keep a live LDAP-filter preview in sync as the user edits.
  -->
  <script>
    (function () {
      var bridge = document.getElementById("ls-bridge");
      if (!bridge) return;
      var SELF_URL = bridge.getAttribute("data-self-url") || "";
      var BASE_URL = SELF_URL.replace(/\/@@senaite_ldapcontrolpanel$/, "");

      // ---- helpers ----
      function textareaValue(id) {
        var ta = document.getElementById(id);
        return ta ? ta.value : "";
      }

      function setTextareaLines(id, items) {
        var ta = document.getElementById(id);
        if (!ta) return;
        ta.value = items.join("\n");
        ta.dispatchEvent(new Event("change"));
      }

      function parseLines(value) {
        return (value || "").split("\n")
          .map(function (s) { return s.trim(); })
          .filter(Boolean);
      }

      function syncTextareaFromPicker(picker) {
        var targetId = picker.getAttribute("data-target");
        var selected = Array.from(picker.selectedOptions)
                            .map(function (o) { return o.value; });
        setTextareaLines(targetId, selected);
      }

      function populatePicker(picker, available, selected) {
        // Merge available + currently-selected so currently-saved
        // values that aren't in the discovered set still show up.
        var merged = {};
        available.forEach(function (oc) { merged[oc] = true; });
        selected.forEach(function (oc) { merged[oc] = true; });
        var keys = Object.keys(merged).sort();

        while (picker.firstChild) picker.removeChild(picker.firstChild);
        keys.forEach(function (oc) {
          var opt = document.createElement("option");
          opt.value = oc;
          opt.textContent = oc;
          if (selected.indexOf(oc) !== -1) opt.selected = true;
          picker.appendChild(opt);
        });
      }

      function discover(picker, statusEl) {
        var which = picker.getAttribute("data-which");
        statusEl.textContent = "Loading…";
        fetch(
          BASE_URL + "/@@senaite_ldapdiscover_objectclasses?which=" +
            encodeURIComponent(which),
          { credentials: "same-origin" }
        )
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (!data.ok) {
              statusEl.textContent = "Discovery failed: " + data.error;
              return;
            }
            var targetId = picker.getAttribute("data-target");
            var current = parseLines(textareaValue(targetId));
            populatePicker(picker, data.object_classes, current);
            statusEl.textContent =
              "Found " + data.object_classes.length +
              " object class(es) from " + data.sampled +
              " sampled entries.";
          })
          .catch(function (err) {
            statusEl.textContent = "Discovery failed: " + err;
          });
      }

      function initPicker(picker) {
        var targetId = picker.getAttribute("data-target");
        var current = parseLines(textareaValue(targetId));
        // Show what we currently have, even before clicking refresh.
        populatePicker(picker, [], current);
        picker.addEventListener("change", function () {
          syncTextareaFromPicker(picker);
        });
      }

      // Wire up the two pickers.
      ["f-users-oc-picker", "f-groups-oc-picker"].forEach(function (id) {
        var picker = document.getElementById(id);
        if (picker) initPicker(picker);
      });

      // Wire up "Refresh from server" buttons.
      document.querySelectorAll("[data-action='discover-oc']")
        .forEach(function (btn) {
          btn.addEventListener("click", function () {
            var picker = document.getElementById(
              btn.getAttribute("data-picker"));
            if (!picker) return;
            // data-status="f-users-oc-status" matches picker
            // "f-users-oc-picker" by replacing -picker with -status.
            var statusId = picker.id.replace(/-picker$/, "-status");
            var status = document.querySelector(
              "[data-status='" + statusId + "']");
            if (status) discover(picker, status);
          });
        });

      // "edit raw" links: reveal the underlying textarea.
      document.querySelectorAll("a.reveal-textarea")
        .forEach(function (link) {
          link.addEventListener("click", function (ev) {
            ev.preventDefault();
            var id = link.getAttribute("data-target");
            var ta = document.getElementById(id);
            if (ta) ta.classList.toggle("d-none");
          });
        });

      // ---- Live filter preview ----
      // Mirrors what node.ext.ldap will send: an AND of the
      // queryFilter (if any) and an OR of objectClass clauses.
      function buildFilter(which) {
        var ocId = "f-" + which + "-oc";
        var queryId = which === "users"
          ? "f-users-query" : "f-groups-query";
        var ocs = parseLines(textareaValue(ocId));
        var query = (document.getElementById(queryId) || {}).value || "";
        query = query.trim();

        var ocPart = "";
        if (ocs.length === 1) {
          ocPart = "(objectClass=" + ocs[0] + ")";
        } else if (ocs.length > 1) {
          ocPart = "(|" + ocs.map(function (oc) {
            return "(objectClass=" + oc + ")";
          }).join("") + ")";
        }

        if (ocPart && query) return "(&" + ocPart + query + ")";
        return ocPart || query || "(objectClass=*)";
      }

      function updatePreviews() {
        document.querySelectorAll("[data-filter-preview]")
          .forEach(function (el) {
            var which = el.getAttribute("data-filter-preview");
            el.textContent = buildFilter(which);
          });
      }

      // Trigger preview update on every relevant change.
      ["f-users-oc", "f-users-query",
       "f-groups-oc", "f-groups-query"].forEach(function (id) {
        var el = document.getElementById(id);
        if (el) {
          el.addEventListener("input", updatePreviews);
          el.addEventListener("change", updatePreviews);
        }
      });
      updatePreviews();
    })();
  </script>

  <!-- Inline LDAP-search JS. Uses createElement throughout so
       Chameleon doesn't choke on JS-string close-tag literals. -->
  <script>
    (function () {
      var bridge = document.getElementById("ls-bridge");
      if (!bridge) return;
      var USERS_BASE = bridge.getAttribute("data-users-base") || "";
      var GROUPS_BASE = bridge.getAttribute("data-groups-base") || "";
      var SELF_URL = bridge.getAttribute("data-self-url") || "";
      var BASE_URL = SELF_URL.replace(/\/@@senaite_ldapcontrolpanel$/, "");

      window.ldapSearch = {

        onBaseChange: function () {
          var base = document.getElementById("ls-base").value;
          var input = document.getElementById("ls-base-dn");
          if (base === "users") {
            input.value = USERS_BASE;
            input.disabled = true;
          } else if (base === "groups") {
            input.value = GROUPS_BASE;
            input.disabled = true;
          } else {
            input.disabled = false;
            input.focus();
          }
        },

        setStatus: function (msg, level) {
          var status = document.getElementById("ls-status");
          while (status.firstChild) status.removeChild(status.firstChild);
          if (!msg) return;
          var div = document.createElement("div");
          div.className = "alert alert-" + (level || "info") + " py-2 mb-0";
          div.textContent = msg;
          status.appendChild(div);
        },

        run: function () {
          var base = document.getElementById("ls-base").value;
          var baseDn = document.getElementById("ls-base-dn").value;
          var filter = document.getElementById("ls-filter").value;
          var scope = document.getElementById("ls-scope").value;

          var url = BASE_URL + "/@@senaite_ldapsearch_results"
                  + "?base=" + encodeURIComponent(base)
                  + "&base_dn=" + encodeURIComponent(baseDn)
                  + "&filter=" + encodeURIComponent(filter)
                  + "&scope=" + encodeURIComponent(scope);

          this.setStatus("Searching…", "secondary");

          var self = this;
          fetch(url, { credentials: "same-origin" })
            .then(function (r) { return r.json(); })
            .then(function (data) { self.render(data); })
            .catch(function (err) {
              self.setStatus("Request failed: " + err, "danger");
            });
        },

        render: function (data) {
          var table = document.getElementById("ls-results");
          var tbody = table.querySelector("tbody");
          while (tbody.firstChild) tbody.removeChild(tbody.firstChild);

          if (!data.ok) {
            this.setStatus(data.error || "Unknown error", "danger");
            table.classList.add("d-none");
            return;
          }

          var msg = data.count + " result" +
                    (data.count === 1 ? "" : "s") +
                    " from " + data.base;
          if (data.truncated) msg += " (truncated)";
          this.setStatus(msg, data.count ? "info" : "secondary");

          if (data.count === 0) {
            table.classList.add("d-none");
            return;
          }

          for (var i = 0; i < data.dns.length; i++) {
            var dn = data.dns[i];
            var tr = document.createElement("tr");
            tr.className = "result-row";
            tr.setAttribute("data-dn", dn);
            var td = document.createElement("td");
            td.className = "text-monospace";
            td.textContent = dn;
            tr.appendChild(td);
            tr.addEventListener("click", this.toggleRow.bind(this, tr));
            tbody.appendChild(tr);
          }
          table.classList.remove("d-none");
        },

        toggleRow: function (tr, event) {
          if (event && event.target.closest(".attrs-cell")) return;
          var next = tr.nextElementSibling;
          if (next && next.classList.contains("attrs-row")) {
            tr.classList.remove("is-open");
            next.remove();
            return;
          }
          tr.classList.add("is-open");
          var base = document.getElementById("ls-base").value;
          var dn = tr.getAttribute("data-dn");
          var url = BASE_URL + "/@@senaite_ldapsearch_attrs"
                  + "?base=" + encodeURIComponent(base)
                  + "&dn=" + encodeURIComponent(dn);

          var attrTr = document.createElement("tr");
          attrTr.className = "attrs-row";
          var attrTd = document.createElement("td");
          attrTd.className = "attrs-cell";
          attrTd.textContent = "Loading…";
          attrTr.appendChild(attrTd);
          tr.parentNode.insertBefore(attrTr, tr.nextSibling);

          fetch(url, { credentials: "same-origin" })
            .then(function (r) { return r.json(); })
            .then(function (data) {
              while (attrTd.firstChild) attrTd.removeChild(attrTd.firstChild);
              attrTd.appendChild(buildAttrsBlock(data));
            })
            .catch(function (err) {
              attrTd.textContent = "Failed: " + err;
            });
        }
      };

      function buildAttrsBlock(data) {
        if (!data.ok) {
          var span = document.createElement("span");
          span.className = "text-danger";
          span.textContent = data.error || "Unknown error";
          return span;
        }
        var attrs = data.attrs || {};
        var keys = Object.keys(attrs).sort();
        if (keys.length === 0) {
          var em = document.createElement("em");
          em.className = "text-muted";
          em.textContent = "No attributes";
          return em;
        }
        var table = document.createElement("table");
        table.className = "attrs-table";
        keys.forEach(function (key) {
          var tr = document.createElement("tr");
          var th = document.createElement("th");
          th.textContent = key;
          tr.appendChild(th);
          var td = document.createElement("td");
          var val = attrs[key];
          if (Array.isArray(val)) {
            val.forEach(function (v, i) {
              if (i > 0) td.appendChild(document.createElement("br"));
              td.appendChild(document.createTextNode(v));
            });
          } else {
            td.textContent = val;
          }
          tr.appendChild(td);
          table.appendChild(tr);
        });
        return table;
      }
    })();
  </script>

  </div>

</metal:main>

</body>
</html>
